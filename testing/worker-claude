The critical detail the PRD skeleton missed: hash('sha512', $input, true) uses the raw binary output, then base64-encodes that. If you hash to hex first and then base64 it, you get a completely different result. Every fingerprint fails silently and looks like a tampering attempt.
In Web Crypto (Cloudflare Workers environment):
typescriptasync function sha512Base64(input: string): Promise<string> {
  const encoded = new TextEncoder().encode(input);
  const hashBuf = await crypto.subtle.digest('SHA-512', encoded);
  // base64 encode the raw binary buffer
  return btoa(String.fromCharCode(...new Uint8Array(hashBuf)));
}

export async function buildSendFingerprint(
  posAutCode: string,
  timestamp: string,
  amount: number,
  merchantRef: string,
  merchantSession: string,
  posID: string,
  currency: string,
  transactionCode: string,
  entityCode = '',
  referenceNumber = ''
): Promise<string> {
  const hashedAutCode = await sha512Base64(posAutCode);
  const amountScaled = Math.trunc(amount * 1000);

  const toHash =
    hashedAutCode +
    timestamp +
    String(amountScaled) +
    merchantRef.trim() +
    merchantSession.trim() +
    posID.trim() +
    currency.trim() +
    transactionCode.trim() +
    (entityCode ? String(Number(entityCode)) : '') +
    (referenceNumber ? String(Number(referenceNumber)) : '');

