typescriptimport { createHash } from 'crypto'; // Node-compatible; use Web Crypto in Workers

function sha512Raw(input: string): Buffer {
  return createHash('sha512').update(input, 'utf8').digest();
}

function base64(buf: Buffer): string {
  return buf.toString('base64');
}

// ---- SEND fingerprint (postback.php -> SISP) ----
export function buildSendFingerprint(
  posAutCode: string,
  timestamp: string,         // 'yyyy-MM-dd HH:mm:ss'
  amount: number,            // integer CVE - e.g. 500
  merchantRef: string,
  merchantSession: string,
  posID: string,
  currency: string,          // always '132'
  transactionCode: string,   // '1' for purchase
  entityCode: string,        // '' for purchases
  referenceNumber: string    // '' for purchases
): string {
  const hashedAutCode = base64(sha512Raw(posAutCode));
  const amountScaled = Math.trunc(amount * 1000); // 500 CVE -> 500000

  const toHash =
    hashedAutCode +
    timestamp +
    amountScaled +
    merchantRef +
    merchantSession +
    posID +
    currency +
    transactionCode +
    entityCode +       // only appended when non-empty
    referenceNumber;   // only appended when non-empty

  return base64(sha512Raw(toHash));
}

// ---- RESPONSE fingerprint (callback.php <- SISP) ----
export function buildResponseFingerprint(
  posAutCode: string,
  messageType: string,
  clearingPeriod: string,    // strip leading zeros before concat
  transactionID: string,     // strip leading zeros
  merchantReference: string,
  merchantSession: string,
  amount: string,            // raw string as received, e.g. '1000.00'
  messageID: string,
  pan: string,               // '************1234'
  merchantResponse: string,  // 'C' on success
  timestamp: string,
  reference: string,
  entity: string,
  clientReceipt: string,
  additionalErrorMessage: string,
  reloadCode: string
): string {
